// Florone — schema per employer spec (SQLite + Prisma)
// Core: Category -> MenuItem -> OptionGroup -> OptionItem
//       Table -> Order -> OrderItem -> OrderItemOption

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String   @default("")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItems MenuItem[]
}

model MenuItem {
  id               String   @id @default(cuid())
  categoryId       String
  name             String // Persian display name (nameFA)
  nameEn           String   @default("")
  description      String   @default("")
  imageUrl         String   @default("")
  basePrice        String   @default("") // display string, e.g. "۶۵۰,۰۰۰"
  discount         Int      @default(0)
  prepTime         Int      @default(20)
  isAvailable      Boolean  @default(true)
  isTrending       Boolean  @default(false) // "پرطرفدار"
  featuredFloravan Boolean  @default(false) // "پیشنهاد فلوروان"
  legacyId         Int? // per-category integer id from the original seed
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  optionGroups OptionGroup[]
  orderItems   OrderItem[]
}

model OptionGroup {
  id         String  @id @default(cuid())
  menuItemId String
  title      String
  type       String  @default("single") // "single" | "multiple"
  isRequired Boolean @default(false)
  minSelect  Int     @default(0)
  maxSelect  Int     @default(1)
  sortOrder  Int     @default(0)

  menuItem         MenuItem          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  optionItems      OptionItem[]
  orderItemOptions OrderItemOption[]
}

model OptionItem {
  id            String  @id @default(cuid())
  optionGroupId String
  name          String
  priceDelta    String  @default("") // display string, may be empty
  isDefault     Boolean @default(false)
  sortOrder     Int     @default(0)
  isActive      Boolean @default(true)

  optionGroup      OptionGroup       @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemOption[]
}

model Table {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // maps to the map layout "key"
  layoutId  Int // numeric id shown on the map
  capacity  Int      @default(2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id               String    @id @default(cuid())
  tableId          String
  status           String    @default("active") // active | closed
  paymentStatus    String    @default("unpaid") // unpaid | paid
  publicOrderToken String?
  customerNote     String? // customer comment — intentionally NOT seeded
  subtotal         Int       @default(0)
  discountAmount   Int       @default(0)
  finalAmount      Int       @default(0)
  acknowledged     Boolean   @default(false)
  acknowledgedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  paidAt           DateTime?
  closedAt         DateTime?

  table      Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  menuItemId   String?
  menuItemName String // snapshot
  quantity     Int      @default(1)
  unitPrice    String   @default("") // snapshot display string
  totalPrice   String   @default("") // snapshot display string
  note         String?
  createdAt    DateTime @default(now())

  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem         MenuItem?         @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  orderItemOptions OrderItemOption[]
}

model OrderItemOption {
  id               String   @id @default(cuid())
  orderItemId      String
  optionGroupId    String?
  optionItemId     String?
  optionGroupTitle String   @default("") // snapshot
  optionItemName   String   @default("") // snapshot
  priceDelta       String   @default("")
  createdAt        DateTime @default(now())

  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionGroup OptionGroup? @relation(fields: [optionGroupId], references: [id], onDelete: SetNull)
  optionItem  OptionItem?  @relation(fields: [optionItemId], references: [id], onDelete: SetNull)
}

model CustomPizzaSettings {
  id                      String   @id @default("default")
  basePriceMedium         Int      @default(550000)
  basePriceFamily         Int      @default(780000)
  familyToppingMultiplier Float    @default(1.3)
  minToppings             Int      @default(3)
  maxToppings             Int      @default(6)
  updatedAt               DateTime @updatedAt
}

model CustomPizzaTopping {
  id          String   @id // slug: pepperoni, mushroom, ...
  name        String
  emoji       String   @default("")
  groupKey    String   // protein | vegetable
  priceMedium Int
  available   Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}
